#: data/05_auto.conf:1
msgid "activate IM with @@@-mark in its description"
msgstr "説明中に@@@-マーク付きIMを有効にする"

#: data/21_ibus.conf:1
msgid "activate Intelligent Input Bus (IBus)"
msgstr "インテリジェントインプットバス (IBus)を有効にする"

#: data/23_fcitx5.conf:1
msgid "activate Flexible Input Method Framework v5 (fcitx5)"
msgstr "フレキシブルインプットメソッド v5 (fcitx5) を有効にする"

#: data/24_uim.conf:1
msgid "activate universal input method (uim)"
msgstr "ユニバーサルインプットメソッド (uim) を有効にする"

#: data/25_hime.conf:1
msgid "activate HIME Input Method Editor (hime)"
msgstr "ヒメインプットメソッドエディター (hime) を有効にする"

#: data/26_gcin.conf:1
msgid "activate Chinese input method (gcin)"
msgstr "中国語インプットメソッド (gcin) を有効にする"

#: data/30_maliit.conf:1
msgid "activate Mallit input method framework"
msgstr "Mallit入力メソッド を有効にする"

#: data/48_scim.conf:1
msgid "activate Smart Common Input Method (SCIM)"
msgstr "スマートコモンインプットメソッド (SCIM) を有効にする"

#: data/78_none.conf:1
msgid "do not activate any IM and use the desktop default"
msgstr "いかなる IM も設定せずに、デスクトップのデフォルトを使用"

#: im-config.in:30
#, sh-format
msgid "Input Method Configuration (im-config, ver."
msgstr "インプットメソッド設定 (im-config, ver."

#: im-config.in:31
#, sh-format
msgid "See im-config(8), README.Debian."
msgstr "im-config(8), README.Debia を参照。"

#: im-config.in:103
#, sh-format
msgid "im-config does nothing for the non-X11 environment."
msgstr "im-config は非-X11 環境では何もしません"

#: im-config.in:109 im-config.in:127 im-config.in:144
#, sh-format
msgid "Click Ok to exit this dialog."
msgstr "Ok をクリックしてこのダイアログから脱出。"

#: im-config.in:120
#, sh-format
msgid "Manual modifiation to the configuration file is detected."
msgstr "設定ファイルへの手動変更が検出された。"

#: im-config.in:122 im-config.in:140 im-config.in:253 im-config.in:258
#, sh-format
msgid "Configuration file"
msgstr "設定ファイル"

#: im-config.in:124
#, sh-format
msgid "Keep this file, and manage the IM manually."
msgstr "このファイルを変更せず、IM を手動管理します。"

#: im-config.in:125
#, sh-format
msgid "Remove this file manually, and manage the IM."
msgstr "このファイルを手動削除し、IM を管理します。"

#: im-config.in:138
#, sh-format
msgid "The configuration file exists but is not readable."
msgstr "設定ファイルは存在するが、読めません。"

#: im-config.in:142
#, sh-format
msgid "Check permissions and ownership of this file."
msgstr "このファイルのパーミッションや所有者をチェックします。"

#: im-config.in:155
#, sh-format
msgid "IM framework offering packages are missing."
msgstr "IM フレームワークを提供するパッケージが見当たりません。"

#: im-config.in:157
#, sh-format
msgid ""
"Install some IME plugin packages to enable entering non-ASCII characters."
msgstr ""
"非-ASCII 文字の入力できるように、IME プラグイン パッケージを導入します。"

#: im-config.in:159
#, sh-format
msgid "For example"
msgstr "例えば"

#: im-config.in:192
#, sh-format
msgid "Do you change the IM framework configuration?"
msgstr "IM フレームワーク設定を変更しますか?"

#: im-config.in:196 im-config.in:212
#, sh-format
msgid "Select"
msgstr "選択肢"

#: im-config.in:197
#, sh-format
msgid "No"
msgstr "いいえ(N)"

#: im-config.in:197
#, sh-format
msgid "Accept this configuration."
msgstr "この設定を受け入れる。"

#: im-config.in:198
#, sh-format
msgid "Yes"
msgstr "はい(Y)"

#: im-config.in:198
#, sh-format
msgid "Change this configuration."
msgstr "この設定を変更する。"

#: im-config.in:211
#, sh-format
msgid "Select IM framework from radio buttons"
msgstr "IM フレームワークをラジオボタンから選択"

#: im-config.in:213
#, sh-format
msgid "IM"
msgstr "IM"

#: im-config.in:214 im-config.in:255 im-config.in:260
#, sh-format
msgid "Description"
msgstr "説明"

#: im-config.in:253
#, sh-format
msgid "removed"
msgstr "削除済み"

#: im-config.in:254 im-config.in:259
#, sh-format
msgid "IM framework"
msgstr "IM フレームワーク"

#: im-config.in:255
#, sh-format
msgid "automatically select and activate IM"
msgstr "IM を自動的に選択し起動する"

#: im-config.in:271
#, sh-format
msgid "The configuration file is kept unchanged."
msgstr "設定ファイルは変更されない。"

#: im-config.in:302
#, sh-format
msgid "The configuration file is updated."
msgstr "設定ファイルは更新される。"

#: im-config.in:306
#, sh-format
msgid "Restart the session to activate the new IM."
msgstr "セッションを再開し、新たな IM を起動する。"

#: im-config.desktop.in:2
msgid "Input Method"
msgstr "入力メソッド"

#: im-config.desktop.in:3
msgid "Set Keyboard Input Method"
msgstr "キーボード入力メソッドの設定"

#: im-config.desktop.in:5
msgid "keyboard;input"
msgstr "keyboard;input;キーボード;入力"
