# Default im-config mode (see im-config(8))

# This im-config helps to start best available input method for
# the X11 system

# Conditions are AND-logic
#  * DESKTOP_TO_SETUP_IM
#  * LOCALES_TO_SETUP_IM
#  * DESKTOP_TO_USE_FCITX5
#  * LOCALES_TO_USE_FCITX5

# List of desktop to use some IM over none
DESKTOP_TO_SETUP_IM="ANY"
#DESKTOP_TO_SETUP_IM="except:GNOME"
#DESKTOP_TO_SETUP_IM="KDE:LXQt:XFCE"
#DESKTOP_TO_SETUP_IM=""

# List of locales to use some IM over none
LOCALES_TO_SETUP_IM="ANY"
#LOCALES_TO_SETUP_IM="zh_TW:zh_HK:zh_SG:zh_CN:ja_JP:ko_KR:vi_VN"
#LOCALES_TO_SETUP_IM=""

# List of desktop to use fcitx5 over ibus
#DESKTOP_TO_USE_FCITX5="ANY"
DESKTOP_TO_USE_FCITX5="KDE:LXQt"
#DESKTOP_TO_USE_FCITX5=""

# List of locales to use fcitx5 over ibus
LOCALES_TO_USE_FCITX5="ANY"
#LOCALES_TO_USE_FCITX5="zh_CN:zh_TW:zh_HK:zh_SG"
#LOCALES_TO_USE_FCITX5=""

# Trace commands for debug
# (This may cause problem configuration file generated under console mode)
#IM_CONFIG_SETMODE="-x"

# Verbose output for debug (uncomment following)
#IM_CONFIG_VERBOSE="true"

